{
  "name": "project-dashboard-desktop",
  "productName": "Project Hub",
  "version": "1.2.0",
  "description": "Desktop edition of my personal Project Hub dashboard — a single installable Windows app with durable local storage.",
  "author": "Rizwan Virani",
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "sync": "node scripts/sync-app.mjs",
    "make-icon": "node scripts/make-icon.mjs",
    "start": "npm run sync && electron .",
    "pack": "npm run sync && electron-builder --win --dir",
    "dist": "npm run sync && electron-builder --win",
    "release": "npm run sync && electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.rizwanvirani.project-hub",
    "productName": "Project Hub",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/app",
        "to": "app"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "rizwan-virani",
        "repo": "project-dashboard-desktop"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Project Hub",
      "runAfterFinish": true
    }
  }
}
